<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Viper Application Lock" Manufacturer="Dante" Version="1.0.0.0" UpgradeCode="d65f57a3-b457-418a-a92c-15d2a23eb1eb" Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Standard minimal UI -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" /> <!-- Need a dummy license if Minimal UI is used, or just omit if it allows. Actually WixUI_Minimal requires EULA. We will just use WixUI_InstallDir or create a dummy rtf. -->

    <Property Id="ARPNOREPAIR" Value="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Viper">
        <Component Id="ViperServiceComp" Guid="210b377b-60a6-4448-b4b6-39df9f52f36f">
          <File Id="ViperServiceExe" Source="..\src\Viper.Service\bin\Debug\net10.0\Viper.Service.exe" KeyPath="yes" />
          
          <ServiceInstall Id="ServiceInstaller"
                          Type="ownProcess"
                          Name="ViperService"
                          DisplayName="Viper Application Lock Service"
                          Description="Viper offline application locker - intercepts and locks protected applications."
                          Start="auto"
                          Account="LocalSystem"
                          ErrorControl="normal" />
          
          <ServiceControl Id="ServiceControl" Start="install" Stop="both" Remove="uninstall" Name="ViperService" Wait="yes" />
        </Component>


        <Component Id="ViperWatchdogComp" Guid="98a9644d-045a-4e8c-8f19-33d3c7344937">
          <File Id="ViperWatchdogExe" Source="..\src\Viper.Watchdog\bin\Debug\net10.0\Viper.Watchdog.exe" KeyPath="yes" />
          <File Source="..\src\Viper.Watchdog\bin\Debug\net10.0\Viper.Watchdog.dll" />
          <File Source="..\src\Viper.Watchdog\bin\Debug\net10.0\Viper.Watchdog.runtimeconfig.json" />
          <File Source="..\src\Viper.Watchdog\bin\Debug\net10.0\Viper.Watchdog.deps.json" />
          
          <ServiceInstall Id="WatchdogInstaller"
                          Type="ownProcess"
                          Name="ViperWatchdog"
                          DisplayName="Viper Watchdog Service"
                          Description="Viper watchdog - monitors and restarts the Viper Application Lock Service."
                          Start="auto"
                          Account="LocalSystem"
                          ErrorControl="normal" />
          
          <ServiceControl Id="WatchdogControl" Start="install" Stop="both" Remove="uninstall" Name="ViperWatchdog" Wait="yes" />
        </Component>

        <Component Id="UIExe" Guid="927a4d5e-e478-433b-bf0b-fb3e9c490a6e">
          <File Source="..\src\Viper.UI\bin\Debug\net10.0-windows\Viper.UI.exe" />
          <File Source="..\src\Viper.UI\bin\Debug\net10.0-windows\Viper.UI.dll" />
          <File Source="..\src\Viper.UI\bin\Debug\net10.0-windows\Viper.UI.runtimeconfig.json" />
          <File Source="..\src\Viper.UI\bin\Debug\net10.0-windows\Viper.UI.deps.json" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ViperConfigDir" Name="Viper">
        <Component Id="ViperConfigFolderComp" Guid="72f3e827-b08e-4a6c-9226-c2227d89487c">
          <CreateFolder />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Viper Core" Level="1">
      <ComponentRef Id="ViperServiceComp" />
      <ComponentRef Id="ViperWatchdogComp" />
      <ComponentGroupRef Id="SharedDependencies" />
      <ComponentRef Id="UIExe" />
      <ComponentRef Id="ViperConfigFolderComp" />
    </Feature>

    <!-- Auto-harvest all DLLs and JSONs from Viper.Service bin output to satisfy runtime dependencies -->
    <ComponentGroup Id="SharedDependencies" Directory="INSTALLFOLDER">
      <Files Include="..\src\Viper.Service\bin\Debug\net10.0\**\*.dll" />
      <Files Include="..\src\Viper.Service\bin\Debug\net10.0\**\*.json" />
    </ComponentGroup>


    <!-- Custom Actions to set SDDL and ACLs -->
    <CustomAction Id="SetServiceAcl" Execute="deferred" Impersonate="no" Return="ignore" Directory="TARGETDIR" ExeCommand="sc.exe sdset ViperService D:(A;;CCDCLCSWRPWPDTLOCRSDRCWDWO;;;SY)(A;;CCDCLCSWRPWPDTLOCRSDRCWDWO;;;BA)(A;;CCLCSWLOCRRC;;;IU)(A;;CCLCSWLOCRRC;;;SU)" />
    <CustomAction Id="SetWatchdogAcl" Execute="deferred" Impersonate="no" Return="ignore" Directory="TARGETDIR" ExeCommand="sc.exe sdset ViperWatchdog D:(A;;CCDCLCSWRPWPDTLOCRSDRCWDWO;;;SY)(A;;CCDCLCSWRPWPDTLOCRSDRCWDWO;;;BA)(A;;CCLCSWLOCRRC;;;IU)(A;;CCLCSWLOCRRC;;;SU)" />

    <CustomAction Id="SetFolderAcl1" Execute="deferred" Impersonate="no" Return="ignore" Directory="TARGETDIR" ExeCommand="icacls &quot;[CommonAppDataFolder]Viper&quot; /inheritance:r /grant:r &quot;SYSTEM:(OI)(CI)F&quot; &quot;Administrators:(OI)(CI)F&quot;" />
    <CustomAction Id="SetFolderAcl2" Execute="deferred" Impersonate="no" Return="ignore" Directory="TARGETDIR" ExeCommand="icacls &quot;[CommonAppDataFolder]Viper&quot; /deny &quot;Users:(OI)(CI)W&quot;" />

    <InstallExecuteSequence>
      <Custom Action="SetServiceAcl" After="StartServices" Condition="NOT Installed" />
      <Custom Action="SetWatchdogAcl" After="StartServices" Condition="NOT Installed" />
      <Custom Action="SetFolderAcl1" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="SetFolderAcl2" After="SetFolderAcl1" Condition="NOT Installed" />
    </InstallExecuteSequence>

  </Package>
</Wix>
