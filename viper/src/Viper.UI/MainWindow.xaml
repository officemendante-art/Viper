<Window x:Class="Viper.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viper Application Lock" Height="460" Width="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Primary Action Button (White sharp box with black text) -->
        <Style x:Key="UnlockButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button (Text only / Cancel) -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Buttons (Min/Close) -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="#0C0C0C" BorderBrush="#222222" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Header Bar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons & Hint -->
            </Grid.RowDefinitions>

            <!-- 1. Header Bar -->
            <Border x:Name="HeaderBar" Grid.Row="0" Background="#0E0E0E" BorderBrush="#1F1F1F" BorderThickness="0,0,0,1" MouseDown="Header_MouseDown">
                <Grid Margin="12,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderIcon" Text="🔒" FontSize="12" Margin="0,0,8,0" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderText" Text="VIPER APPLICATION LOCK" 
                                   FontFamily="JetBrains Mono, Consolas, Courier New" FontSize="11" 
                                   Foreground="#888888" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="—" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeBtn_Click"/>
                        <Button Content="✕" Style="{StaticResource WindowControlButtonStyle}" Click="CancelBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Main Content Area -->
            <StackPanel Grid.Row="1" Margin="32,24,32,0">
                
                <!-- Lockdown Warning Box (Hidden in normal mode) -->
                <Border x:Name="LockdownWarningBox" Background="#180A0A" BorderBrush="#4A1C1C" BorderThickness="1" CornerRadius="2" Padding="14,12" Margin="0,0,0,20" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" FontSize="18" Foreground="#E57373" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#DDDDDD" FontSize="12.5" FontFamily="Inter, Segoe UI" LineHeight="18">
                            This app is locked down after too many failed attempts. Enter the master password to restore access.
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Title & Subtitle -->
                <TextBlock x:Name="TitleText" Text="Firefox is locked" 
                           Foreground="#FFFFFF" FontSize="24" FontWeight="Bold" 
                           FontFamily="Inter, Segoe UI" Margin="0,0,0,6"/>

                <TextBlock x:Name="SubtitleText" Text="Enter your password to continue." 
                           Foreground="#888888" FontSize="13.5" 
                           FontFamily="Inter, Segoe UI" Margin="0,0,0,24"/>

                <!-- Label -->
                <TextBlock x:Name="FieldLabel" Text="PASSWORD" 
                           FontFamily="JetBrains Mono, Consolas, Courier New" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888888" Margin="0,0,0,8"/>

                <!-- Password Input Container with Eye Toggle -->
                <Border x:Name="InputBorder" Background="#050505" BorderBrush="#262626" BorderThickness="1" CornerRadius="2" Height="48">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Masked Password Box -->
                        <PasswordBox x:Name="PasswordInput" 
                                     Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"
                                     FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                     CaretBrush="#FFFFFF" PasswordChanged="PasswordInput_PasswordChanged"/>

                        <!-- Plaintext Text Box (when Eye Toggle active) -->
                        <TextBox x:Name="PasswordTextBox" Visibility="Collapsed"
                                 Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"
                                 FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                 CaretBrush="#FFFFFF" TextChanged="PasswordTextBox_TextChanged"/>

                        <!-- Eye Toggle Button -->
                        <Button Grid.Column="1" x:Name="EyeToggleBtn" Content="👁" 
                                Background="Transparent" Foreground="#666666" BorderThickness="0"
                                FontSize="14" Cursor="Hand" Padding="6,0" VerticalAlignment="Center"
                                Click="EyeToggleBtn_Click"/>
                    </Grid>
                </Border>

                <!-- Error & Attempt Feedback -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="#E57373" FontSize="12" 
                           Margin="0,8,0,0" FontFamily="Inter, Segoe UI" Visibility="Collapsed"/>

                <TextBlock x:Name="AttemptText" Text="" Foreground="#777777" FontSize="11" 
                           Margin="0,4,0,0" FontFamily="Inter, Segoe UI" Visibility="Collapsed"/>
            </StackPanel>

            <!-- 3. Bottom Action Bar -->
            <StackPanel Grid.Row="2" Margin="32,0,32,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,24">
                    <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="0,0,16,0" Click="CancelBtn_Click"/>
                    <Button x:Name="UnlockBtn" Content="Unlock" Style="{StaticResource UnlockButtonStyle}" Click="UnlockBtn_Click"/>
                </StackPanel>

                <!-- Demo Hint at Bottom -->
                <TextBlock x:Name="DemoHintText" Text="HINT (DEMO): PASSWORD IS &quot;UNLOCK&quot;" 
                           FontFamily="JetBrains Mono, Consolas" FontSize="10" 
                           Foreground="#3A3A3A" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
