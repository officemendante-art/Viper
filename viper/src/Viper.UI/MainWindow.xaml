<Window x:Class="Viper.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viper App Lock" Height="250" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None" Background="#1E1E1E"
        Loaded="Window_Loaded">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="App Locked" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Enter App Unlock Password:" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordInput" Width="250" Height="30" FontSize="16" Margin="0,0,0,20" Background="#333333" Foreground="White" BorderBrush="#555555"/>
            <Button x:Name="UnlockBtn" Content="Unlock" Width="100" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="UnlockBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
