<Window x:Class="Viper.UI.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="First-Run Setup" Height="520" Width="520"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Primary Solid Black Action Button -->
        <Style x:Key="BlackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#B0B0B0"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button (Back / Cancel) -->
        <Style x:Key="TextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Buttons (Min/Close) -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Header Bar -->
                <RowDefinition Height="*"/>  <!-- Content Area -->
                <RowDefinition Height="Auto"/> <!-- Bottom Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. Header Bar -->
            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#EBEBEB" BorderThickness="0,0,0,1" MouseDown="Header_MouseDown">
                <Grid Margin="12,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔒" FontSize="12" Margin="0,0,8,0" Foreground="#555555" VerticalAlignment="Center"/>
                        <TextBlock Text="FIRST-RUN SETUP" 
                                   FontFamily="JetBrains Mono, Consolas" FontSize="11" 
                                   Foreground="#333333" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="StepIndicatorText" Text="Step 1 of 2" Foreground="#888888" FontSize="12" 
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontFamily="Inter, Segoe UI"/>
                        <Button Content="—" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeBtn_Click"/>
                        <Button Content="✕" Style="{StaticResource WindowControlButtonStyle}" Click="CloseBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Content Area -->
            <Grid Grid.Row="1" Margin="36,24,36,0">
                
                <!-- STEP 1: App Unlock Password -->
                <StackPanel x:Name="Step1Panel" Visibility="Visible">
                    <TextBlock Text="Set your app unlock password" 
                               Foreground="#000000" FontSize="22" FontWeight="Bold" 
                               FontFamily="Inter, Segoe UI" Margin="0,0,0,6"/>

                    <TextBlock Text="You'll enter this each time a protected application is opened." 
                               Foreground="#666666" FontSize="13" 
                               FontFamily="Inter, Segoe UI" Margin="0,0,0,24"/>

                    <!-- Field 1: App Unlock Password -->
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="APP UNLOCK PASSWORD" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AppPassCountText" Text="0 chars" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   Foreground="#888888" HorizontalAlignment="Right"/>
                    </Grid>

                    <Border Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="44" Margin="0,0,0,20">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="AppPassBox" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                         FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                         PasswordChanged="AppPassBox_PasswordChanged"/>
                            <TextBox x:Name="AppPassTextBox" Visibility="Collapsed" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                     FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                     TextChanged="AppPassTextBox_TextChanged"/>
                            <Button Grid.Column="1" x:Name="AppPassEyeBtn" Content="👁" Background="Transparent" Foreground="#888888" 
                                    BorderThickness="0" FontSize="14" Cursor="Hand" Padding="6,0" VerticalAlignment="Center"
                                    Click="AppPassEyeBtn_Click"/>
                        </Grid>
                    </Border>

                    <!-- Field 2: Confirm Password -->
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="CONFIRM PASSWORD" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AppPassConfirmCountText" Text="0 chars" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   Foreground="#888888" HorizontalAlignment="Right"/>
                    </Grid>

                    <Border x:Name="AppConfirmBorder" Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="44" Margin="0,0,0,16">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="AppPassConfirmBox" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                         FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                         PasswordChanged="AppPassConfirmBox_PasswordChanged"/>
                            <TextBox x:Name="AppPassConfirmTextBox" Visibility="Collapsed" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                     FontSize="15" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                     TextChanged="AppPassConfirmTextBox_TextChanged"/>
                            <Button Grid.Column="1" x:Name="AppPassConfirmEyeBtn" Content="👁" Background="Transparent" Foreground="#888888" 
                                    BorderThickness="0" FontSize="14" Cursor="Hand" Padding="6,0" VerticalAlignment="Center"
                                    Click="AppPassConfirmEyeBtn_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="Step1ErrorText" Text="" Foreground="#C0392B" FontSize="12" 
                               FontFamily="Inter, Segoe UI" Visibility="Collapsed" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- STEP 2: Master Password -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock Text="Set your master password" 
                               Foreground="#000000" FontSize="22" FontWeight="Bold" 
                               FontFamily="Inter, Segoe UI" Margin="0,0,0,4"/>

                    <TextBlock Text="Used only for recovery after lockdown." 
                               Foreground="#666666" FontSize="13" 
                               FontFamily="Inter, Segoe UI" Margin="0,0,0,16"/>

                    <!-- Warning Box -->
                    <Border Background="#FDF2F2" BorderBrush="#E5A3A3" BorderThickness="1" CornerRadius="2" Padding="14,12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚠" FontSize="18" Foreground="#C0392B" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="This password cannot be recovered." Foreground="#C0392B" FontSize="13" FontWeight="Bold" 
                                           FontFamily="Inter, Segoe UI" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="11.5" FontFamily="Inter, Segoe UI" LineHeight="16">
                                    If you forget your master password, there is no reset, no recovery email, and no support override. Access to locked applications will be permanently unrecoverable through this app.
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Master Password Field -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="MASTER PASSWORD" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="MasterPassCountText" Text="0 chars" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   Foreground="#888888" HorizontalAlignment="Right"/>
                    </Grid>

                    <Border Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="40" Margin="0,0,0,12">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="MasterPassBox" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                         FontSize="14" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                         PasswordChanged="MasterPassBox_PasswordChanged"/>
                            <TextBox x:Name="MasterPassTextBox" Visibility="Collapsed" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                     FontSize="14" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                     TextChanged="MasterPassTextBox_TextChanged"/>
                            <Button Grid.Column="1" x:Name="MasterPassEyeBtn" Content="👁" Background="Transparent" Foreground="#888888" 
                                    BorderThickness="0" FontSize="13" Cursor="Hand" Padding="4,0" VerticalAlignment="Center"
                                    Click="MasterPassEyeBtn_Click"/>
                        </Grid>
                    </Border>

                    <!-- Confirm Master Password Field -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="CONFIRM MASTER PASSWORD" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="MasterPassConfirmCountText" Text="0 chars" FontFamily="JetBrains Mono, Consolas" FontSize="10.5" 
                                   Foreground="#888888" HorizontalAlignment="Right"/>
                    </Grid>

                    <Border Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="40" Margin="0,0,0,12">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="MasterPassConfirmBox" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                         FontSize="14" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                         PasswordChanged="MasterPassConfirmBox_PasswordChanged"/>
                            <TextBox x:Name="MasterPassConfirmTextBox" Visibility="Collapsed" Background="Transparent" Foreground="#000000" BorderThickness="0"
                                     FontSize="14" FontFamily="JetBrains Mono, Consolas" VerticalContentAlignment="Center"
                                     TextChanged="MasterPassConfirmTextBox_TextChanged"/>
                            <Button Grid.Column="1" x:Name="MasterPassConfirmEyeBtn" Content="👁" Background="Transparent" Foreground="#888888" 
                                    BorderThickness="0" FontSize="13" Cursor="Hand" Padding="4,0" VerticalAlignment="Center"
                                    Click="MasterPassConfirmEyeBtn_Click"/>
                        </Grid>
                    </Border>

                    <!-- Checkbox Acknowledgment -->
                    <CheckBox x:Name="AckCheckBox" Margin="0,4,0,10" Click="AckCheckBox_Click">
                        <TextBlock Text="I understand that this master password cannot be recovered if forgotten." 
                                   Foreground="#333333" FontSize="12" FontFamily="Inter, Segoe UI"/>
                    </CheckBox>

                    <TextBlock x:Name="Step2ErrorText" Text="" Foreground="#C0392B" FontSize="12" 
                               FontFamily="Inter, Segoe UI" Visibility="Collapsed" Margin="0,0,0,8"/>
                </StackPanel>
            </Grid>

            <!-- 3. Bottom Action Buttons -->
            <Grid Grid.Row="2" Margin="36,0,36,24">
                <!-- Step 1 Button -->
                <Button x:Name="ContinueBtn" Content="Continue" Style="{StaticResource BlackButtonStyle}" 
                        HorizontalAlignment="Right" IsEnabled="False" Click="ContinueBtn_Click"/>

                <!-- Step 2 Buttons -->
                <Grid x:Name="Step2Buttons" Visibility="Collapsed">
                    <Button x:Name="BackBtn" Content="Back" Style="{StaticResource TextButtonStyle}" 
                            HorizontalAlignment="Left" Click="BackBtn_Click"/>
                    <Button x:Name="FinishSetupBtn" Content="Finish Setup" Style="{StaticResource BlackButtonStyle}" 
                            HorizontalAlignment="Right" IsEnabled="False" Click="FinishSetupBtn_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
