<Window x:Class="Viper.UI.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viper — First-Time Setup" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None" Background="#1E1E1E">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
            <TextBlock Text="Viper Setup" Foreground="White" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"
                       FontFamily="Inter, Segoe UI"/>
            
            <Border Background="#2A1A1A" CornerRadius="4" Padding="12" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" Foreground="#FF6B6B" FontSize="12"
                           FontFamily="Inter, Segoe UI">
                    ⚠ WARNING: The Master Password cannot be recovered. If you forget it,
                    the only option is to uninstall Viper (requires Administrator access).
                    Choose something you will remember.
                </TextBlock>
            </Border>

            <TextBlock Text="Create Master Password:" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,4"
                       FontFamily="Inter, Segoe UI"/>
            <PasswordBox x:Name="MasterPasswordInput" Width="360" Height="32" FontSize="14" Margin="0,0,0,4"
                         Background="#333333" Foreground="White" BorderBrush="#555555"
                         FontFamily="JetBrains Mono, Consolas"/>
            <PasswordBox x:Name="MasterPasswordConfirm" Width="360" Height="32" FontSize="14" Margin="0,0,0,16"
                         Background="#333333" Foreground="White" BorderBrush="#555555"
                         FontFamily="JetBrains Mono, Consolas"/>
            <TextBlock Text="Confirm Master Password above" Foreground="#666666" FontSize="11" Margin="0,-12,0,16"
                       FontFamily="Inter, Segoe UI"/>

            <TextBlock Text="Create App Unlock Password:" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,4"
                       FontFamily="Inter, Segoe UI"/>
            <PasswordBox x:Name="AppPasswordInput" Width="360" Height="32" FontSize="14" Margin="0,0,0,4"
                         Background="#333333" Foreground="White" BorderBrush="#555555"
                         FontFamily="JetBrains Mono, Consolas"/>
            <PasswordBox x:Name="AppPasswordConfirm" Width="360" Height="32" FontSize="14" Margin="0,0,0,16"
                         Background="#333333" Foreground="White" BorderBrush="#555555"
                         FontFamily="JetBrains Mono, Consolas"/>
            <TextBlock Text="Confirm App Unlock Password above" Foreground="#666666" FontSize="11" Margin="0,-12,0,20"
                       FontFamily="Inter, Segoe UI"/>

            <TextBlock x:Name="ErrorText" Text="" Foreground="#FF6B6B" FontSize="12" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"
                       FontFamily="Inter, Segoe UI"/>

            <Button x:Name="SetupBtn" Content="Complete Setup" Width="160" Height="38"
                    Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold"
                    FontSize="14" Click="SetupBtn_Click"
                    FontFamily="Inter, Segoe UI"/>
        </StackPanel>
    </Grid>
</Window>
