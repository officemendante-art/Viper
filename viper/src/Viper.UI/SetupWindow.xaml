<Window x:Class="Viper.UI.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viper — First-Time Setup" Height="520" Width="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="JetBrains Mono, Consolas, Courier New"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <Border Background="#0A0A0A" CornerRadius="8" BorderBrush="#1A1A1A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.8" Color="Black"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,28">
                <!-- Header -->
                <TextBlock Text="🛡️" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Viper Setup" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,4"
                           FontFamily="Inter, Segoe UI"/>
                <TextBlock Text="Set your passwords to get started" 
                           Foreground="#666666" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"
                           FontFamily="Inter, Segoe UI"/>

                <!-- Warning -->
                <Border Background="#1A1111" CornerRadius="4" Padding="14" Margin="0,0,0,24"
                        BorderBrush="#331111" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="⚠  Important" Foreground="#CC4444" FontSize="12" FontWeight="Bold"
                                   Margin="0,0,0,4" FontFamily="Inter, Segoe UI"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AA5555" FontSize="11"
                                   FontFamily="Inter, Segoe UI" LineHeight="18">
                            The Master Password cannot be recovered if forgotten. The only recovery 
                            option is to uninstall Viper (requires Administrator access). Choose 
                            something you will remember.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Master Password -->
                <TextBlock Text="MASTER PASSWORD" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"
                           FontSize="11" Foreground="#777777"/>
                <PasswordBox x:Name="MasterPasswordInput" Style="{StaticResource PasswordField}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="MasterPasswordConfirm" Style="{StaticResource PasswordField}" Margin="0,0,0,4"/>
                <TextBlock Text="Confirm password  ·  Minimum 6 characters" Foreground="#555555" FontSize="10" 
                           Margin="0,0,0,20" FontFamily="Inter, Segoe UI"/>

                <!-- App Unlock Password -->
                <TextBlock Text="APP UNLOCK PASSWORD" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"
                           FontSize="11" Foreground="#777777"/>
                <PasswordBox x:Name="AppPasswordInput" Style="{StaticResource PasswordField}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="AppPasswordConfirm" Style="{StaticResource PasswordField}" Margin="0,0,0,4"/>
                <TextBlock Text="Confirm password  ·  Minimum 4 characters" Foreground="#555555" FontSize="10" 
                           Margin="0,0,0,16" FontFamily="Inter, Segoe UI"/>

                <!-- Error -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="#CC4444" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           FontFamily="Inter, Segoe UI"/>

                <!-- Button -->
                <Button x:Name="SetupBtn" Content="Complete Setup" 
                        Style="{StaticResource PrimaryButton}" 
                        HorizontalAlignment="Center"
                        Click="SetupBtn_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
