<Window x:Class="Viper.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viper Setup" Height="420" Width="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ResizeMode="NoResize"
        FontFamily="Inter">
    <Border Background="#FFFFFF" CornerRadius="2" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="🔒 VIPER SETUP" FontFamily="JetBrains Mono" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="Minimize_Click" Content="—" Background="Transparent" BorderThickness="0" Foreground="#888" Width="40" FontFamily="Segoe UI" Cursor="Hand"/>
                    <Button Click="Close_Click" Content="✕" Background="Transparent" BorderThickness="0" Foreground="#888" Width="40" FontFamily="Segoe UI" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="32,20,32,0">
                <TextBlock Text="Create your password" FontSize="22" FontWeight="Bold" Foreground="#0A0A0A" Margin="0,0,0,4"/>
                <TextBlock Text="You'll enter this each time a protected application is opened." FontSize="13" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,24"/>

                <Grid Margin="0,0,0,6">
                    <TextBlock Text="PASSWORD" FontFamily="JetBrains Mono" FontSize="10.5" FontWeight="SemiBold" Foreground="#666666"/>
                </Grid>
                <Border Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="40" Margin="0,0,0,16">
                    <Grid>
                        <PasswordBox x:Name="PwdBox" PasswordChanged="PwdBox_PasswordChanged" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0,32,0" FontFamily="JetBrains Mono" FontSize="14"/>
                        <TextBox x:Name="TxtBox" TextChanged="TxtBox_TextChanged" Visibility="Collapsed" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0,32,0" FontFamily="JetBrains Mono" FontSize="14"/>
                        <Button x:Name="EyeBtn1" Click="EyeBtn1_Click" Content="👁" HorizontalAlignment="Right" Width="32" Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,6">
                    <TextBlock Text="CONFIRM PASSWORD" FontFamily="JetBrains Mono" FontSize="10.5" FontWeight="SemiBold" Foreground="#666666"/>
                </Grid>
                <Border Background="#F9F9F9" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="2" Height="40" Margin="0,0,0,16">
                    <Grid>
                        <PasswordBox x:Name="ConfirmPwdBox" PasswordChanged="ConfirmPwdBox_PasswordChanged" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0,32,0" FontFamily="JetBrains Mono" FontSize="14"/>
                        <TextBox x:Name="ConfirmTxtBox" TextChanged="ConfirmTxtBox_TextChanged" Visibility="Collapsed" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0,32,0" FontFamily="JetBrains Mono" FontSize="14"/>
                        <Button x:Name="EyeBtn2" Click="EyeBtn2_Click" Content="👁" HorizontalAlignment="Right" Width="32" Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand"/>
                    </Grid>
                </Border>

                <CheckBox x:Name="StartupCheckBox" Content="Launch Viper at Windows startup" IsChecked="True" Foreground="#333333" FontSize="13" Margin="0,4,0,0"/>

                <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12" Margin="0,16,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Bottom -->
            <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EAEAEA" BorderThickness="0,1,0,0">
                <Button x:Name="FinishBtn" Click="FinishBtn_Click" IsEnabled="False" Content="Finish" Background="#0A0A0A" Foreground="#FFFFFF" FontFamily="Inter" FontSize="14" FontWeight="SemiBold" Width="100" Height="32" HorizontalAlignment="Right" Margin="0,0,32,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
